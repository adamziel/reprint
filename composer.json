{
    "name": "wordpress/mysql-dump-producer",
    "description": "MySQL dump producer with cursor-based reentrancy for WordPress data liberation",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0",
        "phpcompatibility/php-compatibility": "^9.3",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2"
    },
    "autoload": {
        "psr-4": {
            "WordPress\\DataLiberation\\": "wordpress-plugin/generic/"
        }
    },
    "scripts": {
        "test": "cd tests && phpunit --testdox --colors",
        "test:fast": "cd tests && ./run-tests.sh fast",
        "test:large": "cd tests && ./run-tests.sh large",
        "test:coverage": "cd tests && ./run-tests.sh coverage",
        "analyze": "phpstan analyze --memory-limit=1G",
        "compat": "phpcs --standard=PHPCompatibility --runtime-set testVersion 7.4- -ps wordpress-plugin/ importer/ --ignore=wordpress-plugin/wordpress"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
