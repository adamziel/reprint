{
    "main": "packages/streaming-importer/src/import.php",
    "output": "importer.phar",
    "check-requirements": false,

    "directories": [
        "packages/streaming-importer"
    ],

    "finder": [
        {
            "name": "*.php",
            "exclude": [
                "tests", "test", "Tests", "Test",
                "docs", "doc", "examples", "bin",
                "DataFormatConsumer", "DataFormatProducer",
                "EntityWriter", "EntityReader",
                "Importer"
            ],
            "notName": "/LICENSE.*|CHANGELOG.*|CONTRIBUTING.*|README.*/",
            "in": "vendor"
        },
        {
            "name": "*.php",
            "in": "lib/sqlite-database-integration/wp-includes/parser"
        },
        {
            "name": "*.php",
            "in": "lib/sqlite-database-integration/wp-includes/mysql"
        },
        {
            "name": "*.php",
            "in": "lib/sqlite-database-integration/wp-includes/sqlite"
        },
        {
            "name": "*.php",
            "in": "lib/sqlite-database-integration/wp-includes/sqlite-ast"
        }
    ],

    "files": [
        "packages/streaming-importer/src/VERSION",
        "lib/sqlite-database-integration/constants.php",
        "lib/sqlite-database-integration/php-polyfills.php",
        "lib/sqlite-database-integration/wp-pdo-mysql-on-sqlite.php",
        "lib/sqlite-database-integration/version.php",
        "vendor/autoload.php"
    ],

    "compactors": [
        "KevinGH\\Box\\Compactor\\Php",
        "KevinGH\\Box\\Compactor\\Json"
    ],

    "annotations": false,
    "compression": "GZ",

    "stub": "bin/phar-stub.php"
}
