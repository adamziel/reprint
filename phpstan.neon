includes:
    - phpstan-baseline.neon

parameters:
    bootstrapFiles:
        - phpstan-bootstrap.php
    phpVersion: 70400
    level: 5
    paths:
        - wordpress-plugin
        - importer
    excludePaths:
        analyseAndScan:
            - wordpress-plugin/generic/secrets.php
            - wordpress-plugin/generic/class-sqlite-driver-pdo.php
            - wordpress-plugin/wordpress/
            - wordpress-plugin/index.php
        analyse:
            - importer/lib/mysql-query-stream/
    treatPhpDocTypesAsCertain: false
    scanDirectories:
        - wordpress-plugin/generic
        - lib/sqlite-database-integration/wp-includes/parser
        - lib/sqlite-database-integration/wp-includes/mysql
        - lib/sqlite-database-integration/wp-includes/sqlite
        - lib/sqlite-database-integration/wp-includes/sqlite-ast
