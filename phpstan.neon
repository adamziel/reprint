includes:
    - phpstan-baseline.neon

parameters:
    bootstrapFiles:
        - phpstan-bootstrap.php
    phpVersion: 70400
    level: 5
    paths:
        - packages/streaming-exporter
        - packages/streaming-importer
        - wordpress-plugin
    excludePaths:
        analyseAndScan:
            - packages/streaming-exporter/src/secrets.php
            - packages/streaming-exporter/src/class-sqlite-driver-pdo.php
            - wordpress-plugin/wordpress/
            - wordpress-plugin/index.php
            - wordpress-plugin/vendor/
        analyse:
            - packages/streaming-importer/src/lib/mysql-query-stream/
            - wordpress-plugin/vendor/
    treatPhpDocTypesAsCertain: false
    scanDirectories:
        - packages/streaming-exporter/src
        - lib/sqlite-database-integration/wp-includes/parser
        - lib/sqlite-database-integration/wp-includes/mysql
        - lib/sqlite-database-integration/wp-includes/sqlite
        - lib/sqlite-database-integration/wp-includes/sqlite-ast
