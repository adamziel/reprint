{
    "name": "wp-php-toolkit/reprint-importer",
    "description": "Streaming site importer with CLI and PHAR distribution support",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "wp-php-toolkit/data-liberation": "^0.8.0",
        "wp-php-toolkit/html": "^0.8.0",
        "wp-php-toolkit/reprint-exporter": "*@dev"
    },
    "autoload": {
        "files": [
            "src/lib/sqlite/functions.php",
            "src/lib/wp-stubs.php",
            "src/lib/protocol/constants.php",
            "src/lib/transport/curl-options.php",
            "src/lib/host/functions.php",
            "src/lib/target-runtime/route-handlers/wpcloud-thumbnail-generator.php",
            "src/lib/target-runtime/route-handlers/remote-upload-proxy.php",
            "src/lib/target-runtime/functions.php",
            "src/lib/version.php",
            "src/lib/bootstrap.php"
        ],
        "classmap": [
            "src/lib"
        ]
    },
    "bin": [
        "bin/reprint-importer"
    ]
}
